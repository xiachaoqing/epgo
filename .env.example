# 数据库配置 (.env.example)
# 复制此文件为 .env 并填入实际值
# .env 文件不会被提交到 git

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=xiachaoqing
DB_PASSWORD=your_secure_password_here
DB_NAME=epgo_db

# 爬虫代理配置
PROXY_HTTP=http://username:password@proxy.host:port
PROXY_HTTPS=http://username:password@proxy.host:port

# LLM API配置（如果使用）
OPENAI_API_KEY=your_api_key_here
CLAUDE_API_KEY=your_api_key_here

# 应用配置
DEBUG=False
ENVIRONMENT=production

# GitHub Token（用于自动化，如果需要）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxx

# 微信/搜狗爬虫配置
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
